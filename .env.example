# YNAB MCP Server Configuration
# Copy this to .env and fill in your values

# Required: Your YNAB Personal Access Token
# Generate one at: https://app.ynab.com/settings → Developer Settings
YNAB_ACCESS_TOKEN=your-personal-access-token-here

# Optional: Default budget ID
# Most users have one budget — set this to avoid specifying budget_id on every call.
# Use a UUID, or "last-used" to auto-pick the most recently modified budget.
# If omitted and you have exactly one budget, it will be auto-detected.
# YNAB_DEFAULT_BUDGET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Multi-User Support (Optional)
# ---------------------------------------------------------------------------
# Add per-user tokens to give each person their own connector URL.
#
# URL format:  /<username>/mcp
# Example:     /adam/mcp  → uses YNAB_TOKEN_ADAM
#              /sarah/mcp → uses YNAB_TOKEN_SARAH
#              /mcp       → uses YNAB_ACCESS_TOKEN (default)
#
# Usernames are case-insensitive (YNAB_TOKEN_ADAM and YNAB_TOKEN_adam both work).

# YNAB_TOKEN_ADAM=adams-personal-access-token
# YNAB_TOKEN_SARAH=sarahs-personal-access-token

# ---------------------------------------------------------------------------
# Bearer Token Authentication (Optional)
# ---------------------------------------------------------------------------
# When set, every HTTP request must include "Authorization: Bearer <token>".
# Note: Claude.ai connectors don't support Bearer auth, so leave this unset
# if using Claude.ai. Useful for Claude Code / API access.
#
# Generate a strong token: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# MCP_BEARER_TOKEN=your-bearer-token-here
